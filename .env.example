# Supabase — from your NEW Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Stripe — from your Stripe dashboard
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs — create these in your Stripe dashboard
STRIPE_MONTHLY_PRICE_ID=price_monthly_...
STRIPE_YEARLY_PRICE_ID=price_yearly_...

# App URL — your Vercel deployment URL
NEXT_PUBLIC_APP_URL=https://your-project.vercel.app

# Admin email — the email that gets admin access automatically
ADMIN_EMAIL=admin@yourdomain.com
